#!/bin/sh
set -eu

usage() {
	cat <<'EOF'
Usage:
  script/release minor
  script/release patch
  script/release rc
  script/release custom v0.17.0

Options:
  --dry-run   Print the GitHub workflow command without running it.

The GitHub release workflow is the release authority. This script only
dispatches .github/workflows/release.yml on main.
EOF
}

dry_run=0
if [ "${1:-}" = "--dry-run" ]; then
	dry_run=1
	shift
fi

kind="${1:-}"
version="${2:-}"

case "$kind" in
	minor | patch | rc)
		if [ -n "$version" ]; then
			echo "$kind does not accept a version argument" >&2
			usage >&2
			exit 1
		fi
		;;
	custom)
		if [ -z "$version" ]; then
			echo "custom requires a version argument, for example v0.17.0" >&2
			usage >&2
			exit 1
		fi
		;;
	-h | --help | "")
		usage
		exit 0
		;;
	*)
		echo "unknown release kind: $kind" >&2
		usage >&2
		exit 1
		;;
esac

set -- gh workflow run release.yml --repo devbuddy/devbuddy --ref main -f "kind=$kind"
if [ -n "$version" ]; then
	set -- "$@" -f "version=$version"
fi

printf '%s ' "$@"
printf '\n'

if [ "$dry_run" = "0" ]; then
	"$@"
fi
